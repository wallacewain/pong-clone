{
  "name": "Pong",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "postCreateCommand": "npm install -g serve",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Pong Game",
      "onAutoForward": "openBrowser"
    }
  },
  "remoteEnv": {
    "BROWSER": "none"
  }
}
